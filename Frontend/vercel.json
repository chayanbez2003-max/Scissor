{
  "redirects": [
    {
      "source": "/r/:slug",
      "destination": "https://scissor-dk7k.onrender.com/r/:slug",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install"
}
